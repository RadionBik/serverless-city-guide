# Storyteller endpoint (vLLM, OpenAI-compatible).
# Leave LLM_BASE_URL empty to fall back to Nebius Token Factory (dev mode) —
# then set NEBIUS_API_KEY. One model everywhere; empty = Qwen/Qwen3-32B.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
NEBIUS_API_KEY=

# Optional — web-search evidence source; skipped when empty
TAVILY_API_KEY=

# Guide store — local dir, or the bucket mount inside the job
GUIDE_STORE_DIR=guides

LOG_LEVEL=INFO
