# Storyteller endpoint (vLLM, OpenAI-compatible). For local dev: vllm serve <model>
LLM_BASE_URL=https://<your-endpoint-id>.serverless.nebius.cloud/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ

# Optional — web-search evidence source; skipped when empty
TAVILY_API_KEY=

# Guide store — local dir, or the bucket mount inside the job
GUIDE_STORE_DIR=guides

LOG_LEVEL=INFO
